-- ==================== REMOTE BUFFER SYSTEM v5 - CON TSPECIAL ====================
local remote = game.ReplicatedStorage:WaitForChild("ByteNetReliable")
local Players = game.Players
local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()

-- ===== COMANDOS REALES DE BYTENET =====
local BYTENET = {
    use = 44,
    findBall = 43,
    changeStyle = 61,
    clientCFrame = 9,
    replication = 21,
    replication2 = 19,
    MoveDirection = 12,
    useEmote = 41,
}

local buffers = {
    use = string.char(BYTENET.use),
    findBall = string.char(BYTENET.findBall),
    changeStyle = string.char(BYTENET.changeStyle),
    clientCFrame = string.char(BYTENET.clientCFrame),
}

-- ===== HOTBAR =====
local hotbar = player.PlayerGui:WaitForChild("Hotbar")

-- ===== SKILLS =====
local function setSkillName(slot, name, reuse)
    local skill = hotbar.Backpack.Hotbar:FindFirstChild("skill"..slot)
    if skill then
        skill.Base.ToolName.Text = name or ""
        if reuse then
            skill.Base.Reuse.Text = reuse
            skill.Base.Reuse.Visible = true
        end
    end
end

local function showCooldown(slot, duration)
    local skill = hotbar.Backpack.Hotbar:FindFirstChild("skill"..slot)
    if skill and skill:FindFirstChild("Cooldown") then
        local cd = skill.Cooldown
        cd.Visible = true
        cd.Size = UDim2.new(1, 0, -1, 0)
        game.TweenService:Create(cd, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(1, 0, 0, 0)
        }):Play()
        task.delay(duration, function() cd.Visible = false end)
    end
end

-- ===== TSPECIAL CUSTOM =====
local function createTSpecial(slot, name, size, position)
    local buttons = hotbar.Backpack.Hotbar
    
    -- Buscar template
    local template = nil
    for i = 1, 10 do
        local skill = buttons:FindFirstChild("skill"..i)
        if skill then template = skill; break end
    end
    if not template then
        template = hotbar.Backpack.Hotbar:FindFirstChild("TspecialerX")
    end
    if not template then
        print("❌ No hay template para Tspecial")
        return nil
    end
    
    -- Eliminar si ya existe
    local tspecialName = "TspecialerX_" .. slot
    local existing = hotbar.Backpack.Hotbar:FindFirstChild(tspecialName)
    if existing then existing:Destroy() end
    
    -- Clonar
    local tspecial = template:Clone()
    tspecial.Name = tspecialName
    tspecial.Base.ToolName.Text = name or "Special"
    tspecial.Base.Number.Text = tostring(slot)
    tspecial.Base.Reuse.Text = "Special"
    tspecial.Base.Reuse.Visible = true
    tspecial.Visible = true
    
    -- Tamaño reducido
    local sz = size or 35
    tspecial.Size = UDim2.new(0, sz, 0, sz)
    
    -- Posición
    if position then
        tspecial.Position = position
    end
    
    tspecial.Parent = hotbar.Backpack.Hotbar
    print("✅ Tspecial creada: " .. name)
    return tspecial
end

local function connectTSpecial(slot, callback)
    local tspecial = hotbar.Backpack.Hotbar:FindFirstChild("TspecialerX_" .. slot)
    if tspecial and tspecial.Base and callback then
        tspecial.Base.MouseButton1Down:Connect(callback)
        print("✅ Callback conectado a Tspecial " .. slot)
    end
end

-- ===== AWAKENING =====
local function setAwakening(config)
    if config.bottomText then
        hotbar.MagicHealth.Awakening.Text = config.bottomText
    end
    if config.color1 and config.color2 then
        hotbar.MagicHealth.Health.Frame.UIGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, config.color1),
            ColorSequenceKeypoint.new(1, config.color2)
        })
    end
end

-- ===== COMANDOS =====
local function kickBall(power, curve, direction)
    remote:FireServer(buffer.fromstring(buffers["use"] .. string.char(1)), {
        command = "kick",
        data = {power = power or 100, curve = curve or false, direction = direction}
    })
end

local function grabBall()
    remote:FireServer(buffer.fromstring(buffers["findBall"]))
end

-- ===== EXPORTAR =====
return {
    setSkillName = setSkillName,
    showCooldown = showCooldown,
    createTSpecial = createTSpecial,
    connectTSpecial = connectTSpecial,
    setAwakening = setAwakening,
    kickBall = kickBall,
    grabBall = grabBall,
    buffers = buffers,
}
