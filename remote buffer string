-- ==================== REMOTE BUFFER SYSTEM v4 (DATOS REALES) ====================
local remote = game.ReplicatedStorage:WaitForChild("ByteNetReliable")
local Players = game.Players
local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()

-- ===== COMANDOS REALES DE BYTENET =====
local BYTENET = {
    use = 44,           -- bytenet_use (comando principal)
    findBall = 43,      -- bytenet_findBall
    changeStyle = 61,   -- bytenet_changeStyle
    clientCFrame = 9,   -- bytenet_clientCFrame
    replication = 21,   -- bytenet_replication
    replication2 = 19,  -- bytenet_replication2
    MoveDirection = 12, -- bytenet_MoveDirection
    useEmote = 41,      -- bytenet_useEmote
}

-- ===== BUFFERS =====
local buffers = {
    use = string.char(BYTENET.use),
    findBall = string.char(BYTENET.findBall),
    changeStyle = string.char(BYTENET.changeStyle),
    clientCFrame = string.char(BYTENET.clientCFrame),
}

-- ===== HOTBAR =====
local hotbar = player.PlayerGui:WaitForChild("Hotbar")

-- Crear skills 6-8 clonando skill5
local function createSkillButtons(count)
    for i = 6, count do
        if not hotbar.Backpack.Hotbar:FindFirstChild("skill"..i) then
            local template = hotbar.Backpack.Hotbar.skill5:Clone()
            template.Name = "skill"..i
            template.Base.Number.Text = tostring(i)
            template.Visible = true
            template.Parent = hotbar.Backpack.Hotbar
        end
    end
end

-- Nombre de skill
local function setSkillName(slot, name, reuse)
    local skill = hotbar.Backpack.Hotbar:FindFirstChild("skill"..slot)
    if skill then
        skill.Base.ToolName.Text = name or ""
        if reuse then
            skill.Base.Reuse.Text = reuse
            skill.Base.Reuse.Visible = true
        end
    end
end

-- Cooldown visual
local function showCooldown(slot, duration)
    local skill = hotbar.Backpack.Hotbar:FindFirstChild("skill"..slot)
    if skill and skill:FindFirstChild("Cooldown") then
        local cd = skill.Cooldown
        cd.Visible = true
        cd.Size = UDim2.new(1, 0, -1, 0)
        game.TweenService:Create(cd, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(1, 0, 0, 0)
        }):Play()
        task.delay(duration, function() cd.Visible = false end)
    end
end

-- ===== AWAKENING BAR (ESTRUCTURA REAL) =====
local function setAwakening(config)
    -- MagicHealth > Health > Frame > UIGradient (barra principal)
    -- MagicHealth > Awakening (nombre abajo)
    -- MagicHealth > TextLabel (descripción)
    
    if config.topText then
        hotbar.MagicHealth.TextLabel.Visible = true
        hotbar.MagicHealth.TextLabel.Text = config.topText
    end
    
    if config.bottomText then
        hotbar.MagicHealth.Awakening.Text = config.bottomText
    end
    
    if config.color1 and config.color2 then
        -- Health > Frame > UIGradient
        hotbar.MagicHealth.Health.Frame.UIGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, config.color1),
            ColorSequenceKeypoint.new(1, config.color2)
        })
    end
    
    if config.description then
        hotbar.MagicHealth.saeText.Text = config.description or ""
    end
end

-- ===== COMANDOS BUFFER =====
local function sendUse(cmd, data)
    remote:FireServer(buffer.fromstring(buffers["use"] .. string.char(1)), {
        command = cmd,
        data = data or {}
    })
end

-- Ball
local function grabBall()
    remote:FireServer(buffer.fromstring(buffers["findBall"]))
end

local function kickBall(power, curve, direction)
    sendUse("kick", {
        power = power or 100,
        curve = curve or false,
        direction = direction
    })
end

-- Skills
local function createSkill(slot, name, cd, reuse)
    createSkillButtons(slot)
    setSkillName(slot, name, reuse)
end

local function useSkill(slot, cd)
    sendUse("skill"..slot)
    if cd then showCooldown(slot, cd) end
end

-- Movement
local function dash(direction, distance)
    sendUse("dash", {
        direction = direction,
        distance = distance or 50
    })
end

-- State
local function setStun(duration)
    if char and char.state then
        char.state.stun.Value = true
        task.delay(duration, function()
            if char and char.state then
                char.state.stun.Value = false
            end
        end)
    end
end

local function setHipHeight(height)
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.HipHeight = height end
    end
end

-- Style
local function changeStyle(style)
    remote:FireServer(buffer.fromstring(buffers["changeStyle"]), {style})
end

-- ===== EXPORTAR =====
return {
    createSkillButtons = createSkillButtons,
    setSkillName = setSkillName,
    showCooldown = showCooldown,
    setAwakening = setAwakening,
    grabBall = grabBall,
    kickBall = kickBall,
    createSkill = createSkill,
    useSkill = useSkill,
    dash = dash,
    setStun = setStun,
    setHipHeight = setHipHeight,
    changeStyle = changeStyle,
    sendUse = sendUse,
    buffers = buffers,
}
