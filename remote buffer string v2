   A lightweight buffer string system for creating custom movesets.
   Designed to be used with any character in Azure Latch.
   
   FUNCTIONS:
   
   grabBall(config)
     - config.loop (bool): Keep grabbing until you have the ball
     - config.maxAttempts (number): Attempts per grab
   
   setStun(duration, disableRotate)
     - duration (number): Seconds to stun
     - disableRotate (bool): Prevent character rotation
   
   passBall(config)
     - config.power (number): Shot power (auto-calculated if teammate found)
     - config.maxDistance (number): Max search distance for teammate
     - Automatically finds the closest teammate and passes to them
   
   kickBall(config)
     - config.power (number): Shot power (default: 100)
     - config.direction (Vector3): Direction to kick
     - config.curve (string): "Left" or "Right" for curved shots
   
   setSkillName(slot, name, reuse)
     - slot (number): Skill slot (1-5)
     - name (string): Display name
     - reuse (string): Reuse text (e.g. "Ball", "Shot", "Movement")
   
   showCooldown(slot, duration)
     - slot (number): Skill slot
     - duration (number): Cooldown in seconds
   
   setupTSpecial(config)
     - config.name (string): Button name
     - config.position (string): "left", "right", "top", "bottom" or UDim2
     - config.size (number): Button size in pixels
     - config.callback (function): Function to call on click
   
   setAwakening(config)
     - config.bottomText (string): Awakening name
     - config.color1 (Color3): Bar color start
     - config.color2 (Color3): Bar color end
   
   changeStyle(style)
     - style (string): Style name (e.g. "exe", "messi", "izayoi")
   
   Authors: jonathabejose-alt & Daffy_734
   Github: https://github.com/jonathabejose-alt/Moveset-Hub
   Original Remote Buffer: https://pastebin.com/raw/8XJh7dzh
]]

local remote = game.ReplicatedStorage:WaitForChild("ByteNetReliable")
local Players = game.Players
local player = Players.LocalPlayer
local RunService = game:GetService("RunService")

local buffers = {}
local info = game.ReplicatedStorage.BytenetStorage.Networking.Value
local baseNum = info:match('"bytenet_use"%s*:%s*(%d+)')
local grabballNum = info:match('"bytenet_findBall"%s*:%s*(%d+)')
if baseNum then buffers.base = string.char(tonumber(baseNum)) .. string.char(1) end
if grabballNum then buffers.grabball = string.char(tonumber(grabballNum)) end

local hotbar = player.PlayerGui:WaitForChild("Hotbar")
local buttons = hotbar.Backpack.Hotbar

local grabConnection = nil
local function grabBall(config)
    local conf = config or {}
    if grabConnection then grabConnection:Disconnect(); grabConnection = nil; return end
    local char = player.Character
    if not char or char:FindFirstChild("Ball") then return end
    local root = char:WaitForChild("HumanoidRootPart")
    local targetPart = workspace.Terrain:FindFirstChild("Ball")
    if not targetPart then return end
    local savedRotation = root.CFrame - root.Position
    local function doGrab()
        local c = player.Character
        if not c or c:FindFirstChild("Ball") then if grabConnection then grabConnection:Disconnect(); grabConnection = nil end; return end
        local r = c:FindFirstChild("HumanoidRootPart")
        local ball = workspace.Terrain:FindFirstChild("Ball")
        if not r or not ball then return end
        local pos = ball.Position
        local correctedPos = Vector3.new(pos.X, pos.Y - 3, pos.Z)
        r.CFrame = CFrame.new(correctedPos) * savedRotation
        for _ = 1, (conf.maxAttempts or 3) do remote:FireServer(buffer.fromstring(buffers["grabball"])) end
    end
    doGrab()
    if conf.loop then grabConnection = RunService.Heartbeat:Connect(doGrab) end
end

local function stopGrab()
    if grabConnection then grabConnection:Disconnect(); grabConnection = nil end
end

local function setStun(duration, disableRotate)
    local char = player.Character
    if not char then return end
    if disableRotate then char:SetAttribute("disableRotate", true) end
    local startTime = tick()
    while tick() - startTime < (duration or 0.5) do
        if not char or not char.Parent then break end
        if char.state then char.state.stun.Value = true end
        task.wait(0.03)
    end
    if char and char.state then char.state.stun.Value = false end
    if disableRotate then char:SetAttribute("disableRotate", false) end
end

local function passBall(config)
    local conf = config or {}
    local char = player.Character
    if not char or not char:FindFirstChild("Ball") then return end
    local root = char.HumanoidRootPart
    local closestTeammate, shortestDistance = nil, conf.maxDistance or 180
    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        if not p.Character then continue end
        if p.Team ~= player.Team then continue end
        if p.Team == game.Teams.lobby then continue end
        local targetRoot = p.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot then continue end
        local dist = (root.Position - targetRoot.Position).Magnitude
        if dist < shortestDistance then shortestDistance = dist; closestTeammate = p end
    end
    local direction, power = nil, conf.power or 50
    if closestTeammate and closestTeammate.Character then
        local targetRoot = closestTeammate.Character.HumanoidRootPart
        local dist = (root.Position - targetRoot.Position).Magnitude
        direction = (targetRoot.Position - root.Position).Unit
        power = math.clamp(dist / 1.4, 18, 95)
    else
        direction = conf.direction or root.CFrame.LookVector
    end
    remote:FireServer(buffer.fromstring(buffers["base"]), {{"kick", power, true, direction}})
end

local function kickBall(config)
    local conf = config or {}
    local power = conf.power or 100
    local direction = conf.direction
    local curve = conf.curve
    if not direction then
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then direction = char.HumanoidRootPart.CFrame.LookVector * power
        else direction = Vector3.new(0, 0, -power) end
    end
    if curve == "Left" then direction = (CFrame.new(Vector3.zero, direction) * CFrame.Angles(0, math.rad(25), 0)).LookVector
    elseif curve == "Right" then direction = (CFrame.new(Vector3.zero, direction) * CFrame.Angles(0, math.rad(-25), 0)).LookVector end
    remote:FireServer(buffer.fromstring(buffers["base"]), {{"kick", power, false, direction}})
end

local function setSkillName(slot, name, reuse)
    local skill = buttons:FindFirstChild("skill"..slot)
    if skill then skill.Base.ToolName.Text = name or ""
        if reuse then skill.Base.Reuse.Text = reuse; skill.Base.Reuse.Visible = true end
    end
end

local function showCooldown(slot, duration)
    local skill = buttons:FindFirstChild("skill"..slot)
    if not skill then skill = hotbar.Backpack.Hotbar:FindFirstChild("TspecialerX_" .. slot) end
    if skill and skill:FindFirstChild("Cooldown") then
        local cd = skill.Cooldown; cd.Visible = true; cd.Size = UDim2.new(1, 0, -1, 0)
        game.TweenService:Create(cd, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 0, 0)}):Play()
        task.delay(duration, function() cd.Visible = false end)
    end
end

local function setupTSpecial(config)
    local conf = config or {}
    local name = conf.name or "Special"; local reuse = conf.reuse or "Special"
    local callback = conf.callback; local size = conf.size or 50
    local position = conf.position or "bottom"
    local tBtn = buttons:FindFirstChild("Tspecialer") or buttons:FindFirstChild("TspecialerX")
    if not tBtn then
        local template = buttons.skill1
        if not template then return end
        tBtn = template:Clone(); tBtn.Name = "Tspecialer"; tBtn.Base.Number.Text = ""; tBtn.Parent = buttons
    end
    tBtn.Size = UDim2.new(0, size, 0, size)
    if typeof(position) == "UDim2" then tBtn.Position = position
    elseif position == "left" then tBtn.Position = UDim2.new(0, 5, 0.5, -size/2)
    elseif position == "right" then tBtn.Position = UDim2.new(1, -size-5, 0.5, -size/2)
    elseif position == "top" then tBtn.Position = UDim2.new(0.5, -size/2, 0, 5)
    else tBtn.Position = UDim2.new(0.5, -size/2, 1, -size-5) end
    tBtn.Base.ToolName.Text = name; tBtn.Base.Reuse.Text = reuse; tBtn.Base.Reuse.Visible = true
    if callback then
        local event = tBtn:FindFirstChild("MouseButton1Click") or tBtn.Base:FindFirstChild("MouseButton1Down")
        if event then event:Connect(callback) end
    end
end

local function setAwakening(config)
    if config.bottomText then hotbar.MagicHealth.Awakening.Text = config.bottomText end
    if config.color1 and config.color2 then
        hotbar.MagicHealth.Health.Frame.UIGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, config.color1), ColorSequenceKeypoint.new(1, config.color2)
        })
    end
end

local function changeStyle(style)
    player:SetAttribute("style", style)
end

return {
    grabBall = grabBall, stopGrab = stopGrab, setStun = setStun,
    passBall = passBall, kickBall = kickBall,
    setSkillName = setSkillName, showCooldown = showCooldown,
    setupTSpecial = setupTSpecial, setAwakening = setAwakening,
    changeStyle = changeStyle, buffers = buffers,
}
