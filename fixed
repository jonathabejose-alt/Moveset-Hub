return {
    grabBall      = grabBall,
    stopGrab      = stopGrab,
    setStun       = setStun,
    passBall      = passBall,
    kickBall      = kickBall,
    setSkillName  = setSkillName,
    createSkill   = createSkill,
    showCooldown  = showCooldown,
    isOnCooldown  = isOnCooldown,
    setupTSpecial = setupTSpecial,
    setAwakening  = setAwakening,
    changeStyle   = changeStyle,
    buffers       = buffers,
}
